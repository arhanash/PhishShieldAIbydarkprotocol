{
  "manifest_version": 3,
  "name": "PhishShield AI",
  "version": "1.0",
  "description": "Real-time AI Phishing Detection System",
  "permissions": ["tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishShield AI"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}